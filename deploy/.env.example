# Configurazione play-go — copiare in .env (mai committare il .env reale)

# Porta/bind (vedi raspi3.md: 3504 libera, bind locale dietro Cloudflare)
PORT=3504
HOST=127.0.0.1
NODE_ENV=production

# Segreto firma cookie di sessione — generare un valore random robusto
COOKIE_SECRET=change-me-with-a-long-random-string

# Percorso DB SQLite (default: ./data/play-go.db)
# DB_PATH=/srv/apps/play-go/data/play-go.db

# Avversario AI
GNUGO_BIN=gnugo
MAX_CONCURRENT_AI=3
